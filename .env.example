# =========================================================
# Clerk Authentication
# Get your keys at: https://dashboard.clerk.com
# =========================================================

# Frontend publishable key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Backend publishable key
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Backend secret key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Webhook signing secret
# Configure webhooks in Clerk Dashboard -> Developer -> Webhooks
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_secret

# =========================================================
# Database (Neon PostgreSQL)
# Create your database at: https://neon.tech
# =========================================================

# PostgreSQL/Neon Database URL
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require